{
    "_version": "1.59.0",
    "sap.app": {
        "id": "com.clearledgr.s4hana.boxpanel",
        "type": "application",
        "i18n": "i18n/i18n.properties",
        "applicationVersion": {
            "version": "0.1.0"
        },
        "title": "{{appTitle}}",
        "description": "{{appDescription}}",
        "resources": "resources.json",
        "ach": "FI-AP",
        "dataSources": {
            "clearledgrAPI": {
                "uri": "/clearledgr-api/extension/",
                "type": "JSON"
            }
        },
        "crossNavigation": {
            "inbounds": {
                "boxpanel-display": {
                    "semanticObject": "SupplierInvoice",
                    "action": "displayBox",
                    "title": "{{appTitle}}",
                    "signature": {
                        "parameters": {
                            "CompanyCode": {"required": true},
                            "SupplierInvoice": {"required": true},
                            "FiscalYear": {"required": true}
                        },
                        "additionalParameters": "allowed"
                    }
                }
            }
        }
    },
    "sap.ui": {
        "technology": "UI5",
        "icons": {
            "icon": "sap-icon://workflow-tasks",
            "favIcon": "",
            "phone": "",
            "phone@2": "",
            "tablet": "",
            "tablet@2": ""
        },
        "deviceTypes": {
            "desktop": true,
            "tablet": true,
            "phone": true
        }
    },
    "sap.ui5": {
        "rootView": {
            "viewName": "com.clearledgr.s4hana.boxpanel.view.BoxPanel",
            "type": "XML",
            "id": "boxPanel",
            "async": true
        },
        "dependencies": {
            "minUI5Version": "1.108.0",
            "libs": {
                "sap.m": {},
                "sap.ui.core": {},
                "sap.ui.layout": {},
                "sap.suite.ui.commons": {}
            }
        },
        "contentDensities": {
            "compact": true,
            "cozy": true
        },
        "models": {
            "i18n": {
                "type": "sap.ui.model.resource.ResourceModel",
                "settings": {
                    "bundleName": "com.clearledgr.s4hana.boxpanel.i18n.i18n"
                }
            },
            "box": {
                "type": "sap.ui.model.json.JSONModel"
            },
            "session": {
                "type": "sap.ui.model.json.JSONModel"
            }
        },
        "resources": {
            "css": [
                {
                    "uri": "css/style.css"
                }
            ]
        },
        "handleValidation": false
    }
}
